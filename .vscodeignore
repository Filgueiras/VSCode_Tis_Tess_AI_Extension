# Excluir tudo de node_modules excepto dependências de runtime do axios
node_modules/**
!node_modules/axios/**
!node_modules/follow-redirects/**
!node_modules/form-data/**
!node_modules/asynckit/**
!node_modules/combined-stream/**
!node_modules/delayed-stream/**
!node_modules/proxy-from-env/**

# Ficheiros de desenvolvimento e documentação
docs/**
*.vsix
.vscode/**
.git/**
.gitignore
token.md
