{
  "name": "tis-tess",
  "displayName": "Tis.ai - Powered by Tess",
  "description": "Assistente de código IA para VS Code — powered by TIS to use Tess.im",
  "version": "2.3.0",
  "publisher": "tis-angola",
  "author": {
    "name": "Marco Guimarães",
    "url": "https://tis.ao"
  },
  "icon": "icon-tis-tess.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Filgueiras/tis-tess"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "tess",
    "ai",
    "chat",
    "assistant",
    "claude",
    "gpt",
    "gemini",
    "tis angola"
  ],
  "activationEvents": [
    "onView:tess.chatView"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tis-sidebar",
          "title": "Tis.ai - Tess",
          "icon": "tis_vector_vscode.svg"
        }
      ]
    },
    "views": {
      "tis-sidebar": [
        {
          "type": "webview",
          "id": "tess.chatView",
          "name": "Chat Tis.ai",
          "icon": "tis_vector_vscode.svg"
        },
        {
          "id": "fileTreeView",
          "name": "Ficheiros do Projecto",
          "type": "tree"
        },
        {
          "id": "tess.historyView",
          "name": "Histórico",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "tess.openChatWithCode",
        "title": "Tis: Chat com Código Actual"
      },
      {
        "command": "tess.openSettings",
        "title": "Tis: Abrir Definições"
      },
      {
        "command": "fileTree.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tess.refreshHistory",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tess.deleteSession",
        "title": "Apagar conversa",
        "icon": "$(trash)"
      },
      {
        "command": "tess.renameSession",
        "title": "Renomear conversa",
        "icon": "$(edit)"
      },
      {
        "command": "tess.clearHistory",
        "title": "Tis: Limpar histórico"
      },
      {
        "command": "tess.loadSession",
        "title": "Carregar conversa"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tess.openChatWithCode",
          "group": "tess@1",
          "when": "editorTextFocus"
        }
      ],
      "view/title": [
        {
          "command": "fileTree.refresh",
          "when": "view == fileTreeView",
          "group": "navigation"
        },
        {
          "command": "tess.refreshHistory",
          "when": "view == tess.historyView",
          "group": "navigation"
        },
        {
          "command": "tess.clearHistory",
          "when": "view == tess.historyView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tess.renameSession",
          "when": "viewItem == historyItem",
          "group": "1_edit@1"
        },
        {
          "command": "tess.deleteSession",
          "when": "viewItem == historyItem",
          "group": "1_edit@2"
        }
      ]
    },
    "configuration": {
      "title": "Tis.ai",
      "properties": {
        "tess.apiKey": {
          "type": "string",
          "default": "",
          "description": "Token de API da plataforma Tess.im. Obtenha em tess.im/dashboard/user/tokens",
          "markdownDescription": "Token de API da plataforma Tess.im. Obtenha em [tess.im/dashboard/user/tokens](https://tess.im/dashboard/user/tokens)"
        },
        "tess.agentId": {
          "type": "string",
          "default": "",
          "description": "ID numérico do agente Tess. Visível no URL do agente: tess.im/dashboard/agents/12345/edit",
          "markdownDescription": "ID numérico do agente Tess. Visível no URL do agente: `tess.im/dashboard/agents/**12345**/edit`"
        }
      }
    }
  },
  "scripts": {
    "package": "npx vsce package",
    "install-ext": "npx vsce package && code --install-extension tis-tess-*.vsix --force"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
