{
  "name": "tis-tess",
  "displayName": "Tis.ai - Powered by Tess",
  "description": "Assistente de código com IA para VS Code — powered by TIS to use Tess.im",
  "version": "3.2.0",
  "publisher": "tis-angola",
  "author": {
    "name": "Marco A. F. Guimarães",
    "url": "https://tis.ao"
  },
  "icon": "icon-tis-tess.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Filgueiras/tis-tess"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "tess",
    "ai",
    "chat",
    "assistant",
    "claude",
    "gpt",
    "gemini",
    "tis angola"
  ],
  "activationEvents": [
    "onView:tess.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tis-sidebar",
          "title": "Tis.ai - Tess",
          "icon": "TIS_vector_vscode.svg"
        }
      ]
    },
    "views": {
      "tis-sidebar": [
        {
          "type": "webview",
          "id": "tess.chatView",
          "name": "Chat Tis.ai",
          "icon": "TIS_vector_vscode.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "tess.openChatWithCode",
        "title": "Tis: Chat com Código Actual"
      },
      {
        "command": "tess.openSettings",
        "title": "Tis: Abrir Definições"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tess.openChatWithCode",
          "group": "tess@1",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Tis.ai",
      "properties": {
        "tess.apiKey": {
          "type": "string",
          "default": "",
          "description": "Token de API da plataforma Tess.im. Obtenha em tess.im/dashboard/user/tokens",
          "markdownDescription": "Token de API da plataforma Tess.im. Obtenha em [tess.im/dashboard/user/tokens](https://tess.im/dashboard/user/tokens)"
        },
        "tess.agentId": {
          "type": "string",
          "default": "",
          "description": "ID numérico do agente Tess. Visível no URL do agente: tess.im/dashboard/agents/12345/edit",
          "markdownDescription": "ID numérico do agente Tess. Visível no URL do agente: `tess.im/dashboard/agents/**12345**/edit`"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true,force:true}); require('fs').rmSync('media', {recursive:true,force:true}); require('fs').readdirSync('.').filter(f=>f.endsWith('.vsix')).forEach(f=>require('fs').rmSync(f));\"",
    "copy-assets": "copyfiles -u 1 src/webview/webview.css src/webview/webview-script.js media",
    "build": "npm run copy-assets && esbuild extension.js --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18",
    "package": "npm run build && npx vsce package",
    "install-ext": "npm run clean && npm run package && bash -c 'code --install-extension tis-tess-*.vsix --force'"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.4",
    "copyfiles": "^2.4.1"
  }
}
